    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Architecture</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;fundamental concepts or properties of a system in its environment embodied in its elements, relationships, and in the principles governing its design and evolution&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Architecture</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureDecision</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;Decisions pertain to system concerns; however, there is often no simple mapping between the two. A decision can affect the architecture in several ways. These can be reflected in the architecture description such as requiring the existence of AD elements; changing the properties of AD elements; triggering trade-off analyses in which some AD elements, including other decisions and concerns, are revised; or raising new concerns.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureDecision</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Decision</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureDescription</IRI>
        <Literal datatypeIRI="&rdf;PlainLiteral">Def.: &quot;work product used to express an architecture&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureDescription</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Description</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureDescriptionElement</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;An AD element is any construct in an architecture description. AD elements are the most primitive constructs discussed in this International Standard. Every stakeholder, concern, architecture viewpoint, architecture view, model kind, architecture model, architecture decision and rationale is considered an AD element.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureDescriptionElement</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Description Element</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureDescriptionLanguage</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;An ADL is any form of expression for use in architecture descriptions. An ADL provides one or more model kinds as a means to frame some concerns for its audience of stakeholders. An ADL can be narrowly focused, defining a single model kind, or widely focused to provide several model kinds, optionally organized into viewpoints. Often an ADL is supported by automated tools to aid the creation, use and analysis of its models&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureDescriptionLanguage</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">NOTE &quot;Examples: Rapide, SysML, Wright, and ArchiMate&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureDescriptionLanguage</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">ADL</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureFramework</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;An architecture framework establishes the conventions, principles and practices to describe architectures of a specific domain of application and/or community of stakeholders&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureFramework</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Examples: Reference Model of Open Distributed Processing (RM-ODP) [ISO/IEC 10746]; Kruchten&apos;s &quot;4+1&quot; view model; Siemens&apos; 4 views method; The Open Group&apos;s Architecture Framework (TOGAF).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureFramework</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Possible uses: &quot;to create architecture descriptions, develop modeling tools and architecting methods, and establishing processes to facilitate communication, commitments and interoperation across multiple projects and/or organizations&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureFramework</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Framework</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureModel</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.6: &quot;Architecture models can be used as &quot;containers&quot; for applying architecture patterns or architecture styles to express fundamental schemes (such as layers, three-tier, peer-to-peer, model-view-controller) within architecture views.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureModel</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;An architecture view is composed of one or more architecture models. An architecture model uses modeling conventions appropriate to the concerns to be addressed. These conventions are specified by the model kind governing that model.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureModel</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Model</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitecturePattern</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Pattern</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureRationale</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;Architecture rationale records explanation, justification or reasoning about architecture decisions that have been made&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureRationale</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;The rationale for a decision can include the basis for a decision, alternatives and trade-offs considered, potential consequences of the decision and citations to sources of additional information.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureRationale</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Rationale</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureStyle</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Style</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureView</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.6: An architecture view shall be composed of one or more architecture models. (from 5.5: architecture models that address all of the concerns framed by its governing viewpoint and cover the whole system from that viewpoint).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureView</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;work product expressing the architecture of a system from the perspective of specific system concerns&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureView</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture View</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureViewpoint</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.7.3: A corresponde rule applying to an architecture description could orignate in the architecture description, in a viewpoint or in an architecture framework or architecture description language.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ArchitectureViewpoint</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;work product establishing the conventions for the construction, interpretation and use of architecture views to frame specific system concerns&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ArchitectureViewpoint</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Architecture Viewpoint</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Concern</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">4.2.3: &quot;A concern could be held by one or more stakeholders&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Concern</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.3: The following concerns shall be considered and when applicable, identified in the architecture description: the purposes of the system; the suitability of the architecture for achieving the system’s purposes; the feasibility of constructing and deploying the system; the potential risks and impacts of the system to its stakeholders throughout its life cycle; maintainability and evolvability of the system.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Concern</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;interest in a system relevant to one or more of its stakeholders&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Correspondence</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;A correspondence defines a relation between AD elements. Correspondences are used to express architecture relations of interest within an architecture description (or between architecture descriptions).&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Correspondence</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">NOTE &quot;A correspondence can be defined between an AD element and itself.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Correspondence</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">NOTE &quot;Correspondences and correspondence rules are used to express and enforce architecture relations such as composition, consistency, traceability, dependency, constraint and obligation.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CorrespondenceRule</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.7.3: &quot;A corresponde rule applying to an architecture description could orignate in the architecture description, in a viewpoint or in an architecture framework or architecture description language.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CorrespondenceRule</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.7.3: An architecture description shall record for each correspondence rule if it holds (i.e., an associated corresponde can be shown to satisfy the rule) or if it is violated (i.e., an ssociation can be shown to not satisfy the rule or when no associated correspondence exists).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CorrespondenceRule</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;A correspondence rule is used to enforce relations within an architecture description.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CorrespondenceRule</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Correspondence Rule</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Environment</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;context determining the setting and circumstances of all influences upon a system&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Environment</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Justification: &quot;The environment of a system is bounded by and understood through the identification and analysis of the system&apos;s stakeholders and their concerns&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Environment</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Environment
</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ModelKind</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;conventions for a type of modelling&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ModelKind</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">NOTE &quot;Examples include data flow diagrams, class diagrams, Petri nets, balance sheets, organization charts and state transition models.&quot;</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ModelKind</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Model Kind</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Multiplicity</IRI>
        <Literal datatypeIRI="&rdf;PlainLiteral">0= 1..0
1= 1
2= 1..*</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Stakeholder</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">5.3: The following stakeholders shall be considered and when applicable, identified in the architecture description: users of the system; operators of the system; acquirers of the system; owners of the system; suppliers of the system; developers of the system; builders of the system; maintainers of the system.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Stakeholder</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;individual, team, organization, or classes thereof, having an interest in a system&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#System</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;as described in [ISO/IEC 15288]: &apos;systems that are man-made and may be configured with one or more of the following: hardware, software, data, humans, processes (e.g., processes for providing service to users), procedures (e.g. operator instructions), facilities, materials and naturally occurring entities&apos;&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#System</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;software-intensive systems as described in [IEEE Std 1471:2000]: &quot;any system where software contributes essential influences to the design, construction, deployment, and evolution of the system as a whole&quot; to encompass &quot;individual applications, systems in the traditional sense, subsystems, systems of systems, product lines, product families, whole enterprises, and other aggregations of interest&quot;.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#affects</IRI>
        <Literal xml:lang="en" datatypeIRI="&rdf;PlainLiteral">Def.: &quot;A decision can affect the architecture description by requiring the existence of AD elements; changing the properties of AD elements; triggering trade-off analyses in which some AD elements, including other decisions and concerns, are revised; or raising new concerns.&quot;</Literal>
    </AnnotationAssertion>
</Ontology>



