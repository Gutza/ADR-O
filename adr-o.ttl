@prefix : <https://w3id.org/adr-o#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix adr-o: <https://w3id.org/adr-o#> .
@prefix adr-odr: <https://w3id.org/adr-o/ADL/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/adr-o#> .

<https://w3id.org/adr-o> rdf:type owl:Ontology ;
                          owl:versionIRI <https://w3id.org/adr-o/0.7.0> ;
                          dcterms:created "2026-04-18"^^xsd:date ;
                          dcterms:modified "2026-05-05"^^xsd:date ;
                          dcterms:creator "Bogdan Stăncescu" ;
                          dcterms:description "A domain-agnostic RDF/OWL 2 ontology for Any Decision Record. Decisions are modelled as graphs of reusable Claims placed by reified facts (ContextFact, DeliberationFact, ExpectedOutcome) into framing, deliberation, and expected-outcome roles, with explicit option pools and typed inter-record relationships."^^adr-o:md ;
                          dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                          dcterms:title "ADR-O: An Ontology for Architecture Decision Records"@en ;
                          rdfs:seeAlso <https://gutza.github.io/ADR-O/> ;
                          owl:versionInfo "0.7.0-alpha" ;
                          skos:scopeNote "ADR-O defines the minimum vocabulary for representing decision records as typed graphs. Records contain metadata, a pool of Alternatives, and ordered lists of reified facts (Context, Deliberation, ExpectedOutcome) that manifest Claims. Status and valences are managed via SKOS schemes. Domain-specific extensions use the core's extension pattern."@en .

#################################################################
#    Annotation properties
#################################################################

dcterms:created rdf:type owl:AnnotationProperty ;
                rdfs:range xsd:date ;
                rdfs:comment "In ADR-O: the original creation date of the resource. Immutable — set once when the resource is first authored and never updated thereafter. On DecisionRecord: the date the record artifact was first created; may be later than the decision date for post-factum records. On owl:Ontology: the date the ontology document was first created."@en ;
                skos:scopeNote "Immutable original-creation timestamp. Pair with dcterms:modified (which tracks subsequent changes) rather than updating this property on revision. dcterms:date is intentionally not used: it is the generic parent of the DC date family and provides less precision than the created/modified pair. On DecisionRecord, distinct from adr-o:decidedAt (the t₀ commitment date) when the log distinguishes decision date from record authorship."@en ;
                adr-o:justifiedBy adr-odr:ADR-0034-timestamp-decisionrecord .


dcterms:date rdf:type owl:AnnotationProperty ;
             rdfs:range xsd:date ;
             rdfs:comment "In ADR-O, use adr-o:decidedAt for t₀ DecisionRecord commitment time and adr-o:observedAt for tn observation time when those semantics are intended."@en ;
             skos:scopeNote "Interoperability timestamp predicate. Keep t₀ and tn semantics explicit via adr-o:decidedAt and adr-o:observedAt."@en ;
             adr-o:justifiedBy adr-odr:ADR-0034-timestamp-decisionrecord .


adr-o:decidedAt rdf:type owl:AnnotationProperty ;
                rdfs:domain adr-o:DecisionRecord ;
                rdfs:range xsd:date ;
                rdfs:comment "The date the decision was actually made (t₀). This is the moment of commitment, which may precede or follow record creation."@en ;
                rdfs:label "decided at"@en ;
                skos:scopeNote "Tier 1 (epistemic core) timestamp for DecisionRecord commitment at t₀. Range is nominally xsd:date; xsd:dateTime is acceptable for automated tooling."@en ;
                adr-o:justifiedBy adr-odr:ADR-0034-timestamp-decisionrecord .


adr-o:observedAt rdf:type owl:AnnotationProperty ;
                 rdfs:domain adr-o:ObservedOutcome ;
                 rdfs:range xsd:date ;
                 rdfs:comment "The date the observation was made (tₙ)."@en ;
                 rdfs:label "observed at"@en ;
                 skos:scopeNote "Observation-time anchor for realized outcomes. Keep distinct from adr-o:decidedAt (t0 commitment)."@en ;
                 adr-o:justifiedBy adr-odr:ADR-0035-observedoutcome-prov-entity .


dcterms:creator rdf:type owl:AnnotationProperty ;
                skos:scopeNote "In ADR-O: the ingress authorship predicate and DC-compatibility layer. Accepts literals or agent IRIs. Tooling expands this to adr-o:authoredBy when absent; adr-o:authoredBy is authoritative if both differ."@en .


dcterms:description rdf:type owl:AnnotationProperty ;
                    skos:scopeNote "In ADR-O: prose-description for a DecisionRecord (summary), Claim (primary payload), or referenced resource annotation. SHOULD be typed as adr-o:md (equivalent to the IANA text/markdown datatype)."@en ;
                    adr-o:justifiedBy adr-odr:ADR-0003-prose-literals-markdown ,
                                       adr-odr:ADR-0017-markdown-properties-as-implemented ,
                                       adr-odr:ADR-0038-minting-markdown-datatype .


dcterms:license rdf:type owl:AnnotationProperty ;
                skos:scopeNote "In ADR-O: per-record license override if different from the log."@en .


dcterms:references rdf:type owl:AnnotationProperty ;
                   rdfs:domain adr-o:DecisionRecord ;
                   rdfs:range rdfs:Resource ;
                   skos:scopeNote "In ADR-O: bibliographic linkage from a DecisionRecord to an external or non-DecisionRecord resource that informed the record. Annotate referenced resources with dcterms:title and dcterms:description (typed as adr-o:md)."@en ;
                   adr-o:justifiedBy adr-odr:ADR-0039-references .


dcterms:modified rdf:type owl:AnnotationProperty ;
                 rdfs:range xsd:date ;
                 rdfs:comment "In ADR-O: the date of the most recent change to the resource. Updated on every substantive revision. On DecisionRecord: covers non-semantic editorial changes only; semantic changes require a new DecisionRecord via adr-o:amends. On owl:Ontology: advanced with each new version release."@en ;
                 rdfs:label "modified"@en ;
                 skos:scopeNote "Mutable last-modified timestamp — the complement of dcterms:created. Together they form the canonical DC lifecycle pair: dcterms:created is set once and frozen; dcterms:modified tracks all subsequent changes. On DecisionRecord, pairs with dcterms:version for non-semantic artifact evolution under the Decision Transaction Principle."@en ;
                 adr-o:justifiedBy adr-odr:ADR-0034-timestamp-decisionrecord .


dcterms:title rdf:type owl:AnnotationProperty ;
              skos:scopeNote "In ADR-O: the human-readable title of a DecisionRecord."@en .


dcterms:version rdf:type owl:AnnotationProperty ;
                skos:scopeNote "In ADR-O: optional version tag for a DecisionRecord. Use only for non-semantic editorial updates in ADR scope (presentation, wording, metadata polish). Semantic change remains ADL scope and requires a new record linked via adr-o:amends."@en .


skos:definition rdf:type owl:AnnotationProperty ;
                skos:scopeNote "In ADR-O: formal definition payload on a Claim or SKOS concept. SHOULD be typed as adr-o:md (equivalent to the IANA text/markdown datatype)."@en ;
                adr-o:justifiedBy adr-odr:ADR-0003-prose-literals-markdown ,
                                   adr-odr:ADR-0017-markdown-properties-as-implemented ,
                                   adr-odr:ADR-0038-minting-markdown-datatype .


skos:note rdf:type owl:AnnotationProperty ;
          skos:scopeNote "In ADR-O: parent of the SKOS note family. On Claims, sub-properties carry supplementary annotation prose. SHOULD be typed as adr-o:md (equivalent to the IANA text/markdown datatype)."@en ;
          adr-o:justifiedBy adr-odr:ADR-0003-prose-literals-markdown ,
                             adr-odr:ADR-0017-markdown-properties-as-implemented ,
                             adr-odr:ADR-0038-minting-markdown-datatype .


adr-o:hasType rdf:type owl:AnnotationProperty ;
              rdfs:domain adr-o:DecisionRecord ;
              rdfs:range skos:Concept ;
              skos:scopeNote "Optional ADR scope metadata indicating the record's domain or category. Profiles may provide the appropriate SKOS concept schemes."@en ;
              adr-o:justifiedBy adr-odr:ADR-0023-add-hastype-annotation-property .


#################################################################
#    Object Properties
#################################################################

adr-o:addresses rdf:type owl:ObjectProperty ;
                rdfs:range adr-o:Concern ;
                rdfs:comment "Links a subject to a Concern it resolves. Domain is unrestricted: canonical use is on Claim; DecisionRecord is allowed as an editorial rollup."@en ;
                rdfs:label "addresses"@en ;
                skos:scopeNote "ADR scope relation from a subject (typically Claim) to a Concern it addresses. This predicate is concern-oriented only and is intentionally separate from any inter-record causal topology in ADL scope."@en ;
                adr-o:justifiedBy adr-odr:ADR-0006-core-relational-predicates ,
                                  adr-odr:ADR-0013-addresses-dual-placement .
                                   


adr-o:amendedBy rdf:type owl:ObjectProperty ;
                owl:inverseOf adr-o:amends ;
                rdfs:domain adr-o:DecisionRecord ;
                rdfs:range adr-o:DecisionRecord ;
                rdfs:comment "ADL scope: inverse of adr-o:amends; links an anchor DecisionRecord to records that amend it. Many to many cardinality."@en ;
                rdfs:label "amended by"@en ;
                adr-o:justifiedBy adr-odr:ADR-0020-amendments .


adr-o:amends rdf:type owl:ObjectProperty ;
             rdfs:domain adr-o:DecisionRecord ;
             rdfs:range adr-o:DecisionRecord ;
             rdfs:comment "ADL scope: a DecisionRecord partially modifies another without replacing it. The anchor remains in force. Many to many cardinality."@en ;
             rdfs:label "amends"@en ;
             adr-o:justifiedBy adr-odr:ADR-0020-amendments .


adr-o:authoredBy rdf:type owl:ObjectProperty ;
                 rdfs:domain adr-o:DecisionRecord ;
                 rdfs:range prov:Agent ;
                 rdfs:comment "Links a DecisionRecord to the agent responsible for authoring the record artifact (RACI: Responsible). Does not necessarily imply implementation ownership."@en ;
                 rdfs:label "authored by"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0021-social-role-predicates ,
                                   adr-odr:ADR-0022-creator-authoredby-coexistence .
                                    


adr-o:chosenAlternative rdf:type owl:ObjectProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain adr-o:DecisionRecord ;
                        rdfs:range adr-o:Alternative ;
                        rdfs:comment "The selected Alternative after deliberation. Functional: at most one per record. Multi-winner decisions use a composite Alternative."@en ;
                        rdfs:label "chosen alternative"@en ;
                        adr-o:justifiedBy adr-odr:ADR-0012-alternatives-and-chosen-option .


adr-o:conflictsWith rdf:type owl:ObjectProperty ,
                             owl:SymmetricProperty ;
                    rdfs:domain adr-o:DecisionRecord ;
                    rdfs:range adr-o:DecisionRecord ;
                    rdfs:comment "Symmetric tension between two DecisionRecords."@en ;
                    rdfs:label "conflicts with"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0006-core-relational-predicates .


adr-o:manifests rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( adr-o:ContextFact
                                            adr-o:DeliberationFact
                                            adr-o:ExpectedOutcome
                                            adr-o:ObservedOutcome
                                          )
                            ] ;
                rdfs:range adr-o:Claim ;
                rdfs:comment "Indicates which specific Claim is manifested by a given Fact. Functional: one Claim per Fact."@en ;
                rdfs:label "manifests"@en ;
                adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts ,
                                  adr-odr:ADR-0027-facts-manifest-considerations .
                                   


adr-o:namedBy rdf:type owl:ObjectProperty ;
              rdfs:domain adr-o:Complaint ;
              rdfs:range prov:Agent ;
              rdfs:comment "The agent who named the triggering situation and thereby initiated the DecisionRecord. Typically the primary stakeholder whose pain motivated the deliberation. Distinct from adr-o:authoredBy (who wrote the record) and adr-o:decidedBy (who is accountable for the decision)."@en ;
              rdfs:label "named by"@en ;
              adr-o:justifiedBy adr-odr:ADR-0037-complaint-reification .


adr-o:consulted rdf:type owl:ObjectProperty ;
                rdfs:domain adr-o:DecisionRecord ;
                rdfs:range prov:Agent ;
                rdfs:comment "The agents consulted during the decision process (RACI: Consulted)."@en ;
                rdfs:label "consulted"@en ;
                adr-o:justifiedBy adr-odr:ADR-0021-social-role-predicates .


adr-o:decidedBy rdf:type owl:ObjectProperty ;
                rdfs:domain adr-o:DecisionRecord ;
                rdfs:range prov:Agent ;
                rdfs:comment "The agent responsible for making the decision (RACI: Accountable)."@en ;
                rdfs:label "decided by"@en ;
                adr-o:justifiedBy adr-odr:ADR-0021-social-role-predicates .


adr-o:deliberationValence rdf:type owl:ObjectProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain adr-o:DeliberationFact ;
                          rdfs:range adr-o:DeliberationValence ;
                          rdfs:comment "ADR scope: the valence of a DeliberationFact's manifested Claim towards the linked Alternative: does the Fact Support, is it Neutral, or Against the Alternative?"@en ;
                          rdfs:label "deliberation valence"@en ;
                          adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence .


adr-o:dependsOn rdf:type owl:ObjectProperty ;
                rdfs:domain adr-o:DecisionRecord ;
                rdfs:range adr-o:DecisionRecord ;
                rdfs:comment "ADL scope: indicates that a DecisionRecord relies on another."@en ;
                rdfs:label "depends on"@en ;
                adr-o:justifiedBy adr-odr:ADR-0006-core-relational-predicates .


adr-o:deprecatedBy rdf:type owl:ObjectProperty ;
                   owl:inverseOf adr-o:deprecates ;
                   rdfs:domain adr-o:DecisionRecord ;
                   rdfs:range adr-o:DecisionRecord ;
                   rdfs:comment "ADL scope: inverse of adr-o:deprecates; links a deprecated DecisionRecord to the record that deprecated it. This does not imply replacement semantics."@en ;
                   rdfs:label "deprecated by"@en ;
                   adr-o:justifiedBy adr-odr:ADR-0041-deprecation-requires-a-deprecating-record .


adr-o:deprecates rdf:type owl:ObjectProperty ;
                 rdfs:domain adr-o:DecisionRecord ;
                 rdfs:range adr-o:DecisionRecord ;
                 rdfs:comment "ADL scope: a DecisionRecord deprecates another DecisionRecord, withdrawing recommendation without asserting a direct successor replacement."@en ;
                 rdfs:label "deprecates"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0041-deprecation-requires-a-deprecating-record .


adr-o:enables rdf:type owl:ObjectProperty ;
              rdfs:domain adr-o:DecisionRecord ;
              rdfs:range adr-o:DecisionRecord ;
              rdfs:comment "ADL scope: a DecisionRecord makes another DecisionRecord possible or easier."@en ;
              rdfs:label "enables"@en ;
              adr-o:justifiedBy adr-odr:ADR-0006-core-relational-predicates .


adr-o:evidence rdf:type owl:ObjectProperty ;
               rdfs:domain adr-o:ObservedOutcome ;
               rdfs:range rdfs:Resource ;
               rdfs:comment "External evidence supporting an observation (for example logs, reports, or metrics)."@en ;
               rdfs:label "evidence"@en ;
               adr-o:justifiedBy adr-odr:ADR-0035-observedoutcome-prov-entity .


adr-o:discoveryType rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain adr-o:ObservedOutcome ;
                    rdfs:range adr-o:DiscoveryType ;
                    rdfs:comment "Classifies whether an ObservedOutcome is Expected, Deducible, or Emergent relative to the t₀ decision context."@en ;
                    rdfs:label "discovery type"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:realizedFrom rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain adr-o:ObservedOutcome ;
                   rdfs:range adr-o:DecisionRecord ;
                   rdfs:comment "Links an ObservedOutcome to the specific DecisionRecord whose effects were realized and observed."@en ;
                   rdfs:label "realized from"@en ;
                   adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:observedBy rdf:type owl:ObjectProperty ;
                 rdfs:domain adr-o:ObservedOutcome ;
                 rdfs:range prov:Agent ;
                 rdfs:comment "The agent who performed the observation."@en ;
                 rdfs:label "observed by"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0035-observedoutcome-prov-entity .


adr-o:permittedBy rdf:type owl:ObjectProperty ;
                rdfs:domain adr-o:Claim ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( adr-o:ExpectedOutcome
                                           adr-o:ObservedOutcome
                                         )
                           ] ;
                  rdfs:comment "ADL scope: links a Claim to a prior decision's ExpectedOutcome or ObservedOutcome that permits it. Modal strength: MAY."@en ;
                  rdfs:label "permitted by"@en ;
                  adr-o:justifiedBy adr-odr:ADR-0032-unified-voice-and-naming .


adr-o:hasAlternative rdf:type owl:ObjectProperty ;
                     rdfs:domain adr-o:DecisionRecord ;
                     rdfs:range adr-o:Alternative ;
                     rdfs:comment "Links a DecisionRecord to its option pool, regardless of selection status."@en ;
                     rdfs:label "has alternative"@en ;
                     adr-o:justifiedBy adr-odr:ADR-0012-alternatives-and-chosen-option .


adr-o:hasContext rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain adr-o:DecisionRecord ;
                 rdfs:range rdf:List ;
                 rdfs:comment "Ordered list of ContextFacts framing the decision. Functional: one list per record."@en ;
                 rdfs:label "has context"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts .


adr-o:hasDeliberation rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain adr-o:DecisionRecord ;
                      rdfs:range rdf:List ;
                      rdfs:comment "Ordered list of DeliberationFacts weighing Alternatives. Functional: one list per record."@en ;
                      rdfs:label "has deliberation"@en ;
                      adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts .


adr-o:hasExpectedOutcome rdf:type owl:ObjectProperty ,
                                  owl:FunctionalProperty ;
                         rdfs:domain adr-o:DecisionRecord ;
                         rdfs:range rdf:List ;
                         rdfs:comment "Ordered list of ExpectedOutcomes — t₀ commitments regarding intended effects. Functional: one list per record."@en ;
                         rdfs:label "has expected outcome"@en ;
                         adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts ,
                                           adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:hasVerdict rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain adr-o:ObservedOutcome ;
                 rdfs:range adr-o:ObservedOutcomeVerdict ;
                 rdfs:comment "The epistemic conclusion of an ObservedOutcome when it plays a verification role. Functional: at most one verdict per observation."@en ;
                 rdfs:label "has verdict"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0030-observations ,
                                   adr-odr:ADR-0033-observation-discovery .


adr-o:hasStatus rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain adr-o:DecisionRecord ;
                rdfs:range adr-o:Status ;
                rdfs:comment "Lifecycle status of a DecisionRecord. Range is the adr-o:statusScheme."@en ;
                rdfs:label "has status"@en ;
                adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:informed rdf:type owl:ObjectProperty ;
               rdfs:domain adr-o:DecisionRecord ;
               rdfs:range prov:Agent ;
               rdfs:comment "Agents to be informed about the decision (RACI: Informed)."@en ;
               rdfs:label "informed"@en ;
               adr-o:justifiedBy adr-odr:ADR-0021-social-role-predicates .


adr-o:onAlternative rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( adr-o:DeliberationFact
                                                adr-o:ExpectedOutcome
                                              )
                                ] ;
                    rdfs:range adr-o:Alternative ;
                    rdfs:comment "Links a Fact to the Alternative it concerns. Required on DeliberationFact; optional on ExpectedOutcome."@en ;
                    rdfs:label "on alternative"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0012-alternatives-and-chosen-option .


adr-o:outcomeValence rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain adr-o:ExpectedOutcome ;
                     rdfs:range adr-o:ExpectedOutcomeValence ;
                     rdfs:comment "ADR scope: intended valence of an ExpectedOutcome (ExpectedGain, ExpectedCost, ExpectedRisk, ExpectedDependency). A t₀ claim."@en ;
                     rdfs:label "outcome valence"@en ;
                     adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                       adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:promptedBy rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain adr-o:DecisionRecord ;
                 rdfs:range adr-o:Complaint ;
                 rdfs:comment "Links a DecisionRecord to its Complaint — the singular, unconditionally immutable triggering situation that caused the record to exist. Functional by normative intent: exactly one Complaint per record."@en ;
                 rdfs:label "prompted by"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0037-complaint-reification .


adr-o:supersededBy rdf:type owl:ObjectProperty ;
                   owl:inverseOf adr-o:supersedes ;
                   rdfs:domain adr-o:DecisionRecord ;
                   rdfs:range adr-o:DecisionRecord ;
                   rdfs:comment "ADL scope: inverse of adr-o:supersedes; record has been replaced by a successor."@en ;
                   rdfs:label "superseded by"@en ;
                   adr-o:justifiedBy adr-odr:ADR-0006-core-relational-predicates .


adr-o:supersedes rdf:type owl:ObjectProperty ;
                 rdfs:domain adr-o:DecisionRecord ;
                 rdfs:range adr-o:DecisionRecord ;
                 rdfs:comment "ADL scope: a DecisionRecord replaces an earlier one."@en ;
                 rdfs:label "supersedes"@en ;
                 adr-o:justifiedBy adr-odr:ADR-0006-core-relational-predicates .


adr-o:constrainedBy rdf:type owl:ObjectProperty ;
                    rdfs:domain adr-o:Claim ;
                    rdfs:range [ rdf:type owl:Class ;
                                 owl:unionOf ( adr-o:ExpectedOutcome
                                               adr-o:ObservedOutcome
                                             )
                               ] ;
                    rdfs:comment "ADL scope: links a Claim to a prior decision's ExpectedOutcome or ObservedOutcome that constrains it. Modal strength: MUST."@en ;
                    rdfs:label "constrained by"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0025-causal-network ,
                                      adr-odr:ADR-0033-observation-discovery .


adr-o:prohibitedBy rdf:type owl:ObjectProperty ;
                   rdfs:domain adr-o:Claim ;
                   rdfs:range [ rdf:type owl:Class ;
                                owl:unionOf ( adr-o:ExpectedOutcome
                                              adr-o:ObservedOutcome
                                            )
                              ] ;
                   rdfs:comment "ADL scope: links a Claim to a prior decision's ExpectedOutcome or ObservedOutcome that prohibits it. Modal strength: MUST NOT."@en ;
                   rdfs:label "prohibited by"@en ;
                   adr-o:justifiedBy adr-odr:ADR-0025-causal-network ,
                                     adr-odr:ADR-0033-observation-discovery .


adr-o:recommendedBy rdf:type owl:ObjectProperty ;
                rdfs:domain adr-o:Claim ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( adr-o:ExpectedOutcome
                                           adr-o:ObservedOutcome
                                         )
                           ] ;
                rdfs:comment "ADL scope: links a Claim to a prior decision's ExpectedOutcome or ObservedOutcome that recommends it. Modal strength: SHOULD."@en ;
                    rdfs:label "recommended by"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0032-unified-voice-and-naming .


adr-o:discouragedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain adr-o:Claim ;
                  rdfs:range [ rdf:type owl:Class ;
                               owl:unionOf ( adr-o:ExpectedOutcome
                                             adr-o:ObservedOutcome
                                           )
                             ] ;
                  rdfs:comment "ADL scope: links a Claim to a prior decision's ExpectedOutcome or ObservedOutcome that discourages it. Modal strength: SHOULD NOT."@en ;
                    rdfs:label "discouraged by"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0032-unified-voice-and-naming .


adr-o:closedBy rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain adr-o:DecisionRecord ;
               rdfs:range adr-o:Verdict ;
               rdfs:comment "Links a DecisionRecord to the Verdict that closed its deliberation. Functional: one convergence act per decision."@en ;
               rdfs:label "closed by"@en ;
               adr-o:justifiedBy adr-odr:ADR-0040-verdict-reification .


adr-o:justifiedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain rdfs:Resource ;
                  rdfs:range adr-o:DecisionRecord ;
                  rdfs:comment "Project scope: provenance bridge linking a resource (artifact or ontology term) back to its justifying DecisionRecord."@en ;
                  rdfs:label "justified by"@en ;
                  adr-o:justifiedBy adr-odr:ADR-0025-causal-network ,
                                    adr-odr:ADR-0026-ontology-provenance .


adr-o:derivedFrom rdf:type owl:ObjectProperty ;
                  owl:inverseOf adr-o:derives ;
                  rdfs:domain adr-o:Claim ;
                  rdfs:range adr-o:Claim ;
                  rdfs:comment "A Claim is derived from another. Preserves semantic connectivity across records without identity reuse."@en ;
                  rdfs:label "derived from"@en ;
                  adr-o:justifiedBy adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:derives rdf:type owl:ObjectProperty ;
              rdfs:domain adr-o:Claim ;
              rdfs:range adr-o:Claim ;
              rdfs:comment "A Claim serves as the source from which another is derived."@en ;
              rdfs:label "derives"@en ;
              adr-o:justifiedBy adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:satisfies rdf:type owl:ObjectProperty ;
                rdfs:domain adr-o:Alternative ;
                rdfs:range adr-o:Claim ;
                rdfs:comment "ADR scope: indicates that an Alternative satisfies a Claim (typically the Claim manifested in a ContextFact that expresses the record's primary facing concern)."@en ;
                rdfs:label "satisfies"@en ;
                adr-o:justifiedBy adr-odr:ADR-0036-the-satisfies-predicate .


adr-o:verifies rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain adr-o:ObservedOutcome ;
               rdfs:range adr-o:ExpectedOutcome ;
               rdfs:comment "Links an ObservedOutcome to the ExpectedOutcome it evaluates when the observation is used for verification."@en ;
               rdfs:label "verifies"@en ;
               adr-o:justifiedBy adr-odr:ADR-0030-observations ,
                                 adr-odr:ADR-0033-observation-discovery .


adr-o:consolidatedFrom rdf:type owl:ObjectProperty ;
                       owl:inverseOf adr-o:consolidatedIn ;
                       rdfs:domain adr-o:ConsolidatedOutcome ;
                       rdfs:range adr-o:ExpectedOutcome ;
                       rdfs:comment "Links a ConsolidatedOutcome to the source ExpectedOutcome(s) from which it was projected. The forward source-map link: from operative surface to frozen enacted record."@en ;
                       rdfs:label "consolidated from"@en ;
                       skos:scopeNote "Not declared owl:FunctionalProperty: multi-source entries are the normal result of any in-place amendment. The original ExpectedOutcome contributes the semantic substance; the amending ExpectedOutcome contributes the modification. Both links are required for the source map to be honest — pointing to the amending record alone would falsely imply the substance originated there; pointing to the original alone would falsely imply the current text is unchanged. Single-source entries are the common case only for commitments that have never been amended."@en ;
                       adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


adr-o:consolidatedIn rdf:type owl:ObjectProperty ;
                     rdfs:domain adr-o:ExpectedOutcome ;
                     rdfs:range adr-o:ConsolidatedOutcome ;
                     rdfs:comment "Inverse of adr-o:consolidatedFrom. Links a source ExpectedOutcome to its corresponding ConsolidatedOutcome. Absence of this link on an ExpectedOutcome from an active DecisionRecord is a meaningful signal: the commitment is not currently reflected in the consolidated view."@en ;
                     rdfs:label "consolidated in"@en ;
                     adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


adr-o:inConsolidatedADL rdf:type owl:ObjectProperty ,
                                  owl:FunctionalProperty ;
                        rdfs:domain adr-o:ConsolidatedOutcome ;
                        rdfs:range adr-o:ConsolidatedADL ;
                        rdfs:comment "Links a ConsolidatedOutcome to the ConsolidatedADL it belongs to. Functional: one entry belongs to exactly one consolidated document."@en ;
                        rdfs:label "in consolidated ADL"@en ;
                        skos:scopeNote "Follows the skos:inScheme membership pattern with the additional owl:FunctionalProperty constraint that SKOS omits. Functionality enforces the singleton design of ConsolidatedADL: a ConsolidatedOutcome cannot belong to two consolidated documents without violating the one-consolidated-view-per-ADL commitment."@en ;
                        adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


adr-o:consolidatedUpTo rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain adr-o:ConsolidatedADL ;
                       rdfs:range adr-o:DecisionRecord ;
                       rdfs:comment "Links a ConsolidatedADL to the most recently incorporated DecisionRecord. Staleness is computed by comparing this pointer to the most recent Accepted record in the ADL."@en ;
                       rdfs:label "consolidated up to"@en ;
                       skos:scopeNote "Anchored to DecisionRecord IRI, not to a timestamp, per the Decision Transaction Principle. 'Last consolidated to include ADR-0042' is more stable and meaningful than 'last updated on Wednesday'. Advancing this pointer is the final step of every consolidation event."@en ;
                       adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


#################################################################
#    Data properties
#################################################################

adr-o:md rdf:type rdfs:Datatype ;
         owl:equivalentClass <https://www.w3.org/ns/iana/media-types/text/markdown> ;
         rdfs:comment "Ergonomic alias for the IANA text/markdown datatype IRI. Use on all prose-carrying literals per ADR-0003 and ADR-0017."@en ;
         rdfs:label "Markdown"@en ;
         skos:scopeNote "adr-o:md and <https://www.w3.org/ns/iana/media-types/text/markdown> are declared equivalent. The IANA IRI remains authoritative; adr-o:md is the preferred serialization form in ADR-O Turtle files."@en ;
         adr-o:justifiedBy adr-odr:ADR-0038-minting-markdown-datatype .


adr-o:index rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain adr-o:DecisionRecord ;
            rdfs:range xsd:integer ;
            rdfs:comment "Ordering index of a DecisionRecord within its log. Required for chronological sorting."@en ;
            rdfs:label "index"@en ;
            adr-o:justifiedBy adr-odr:ADR-0007-index-vs-identifier .


adr-o:consolidationOrder rdf:type owl:DatatypeProperty ,
                                  owl:FunctionalProperty ;
                         rdfs:domain adr-o:ConsolidatedOutcome ;
                         rdfs:range xsd:integer ;
                         rdfs:comment "Ordering index of a ConsolidatedOutcome within its ConsolidatedADL. Managed by the consolidation tooling layer; the ontology defines the property and range but imposes no ordering constraints or contiguity requirements. Not guaranteed to be persistent or consistent across consolidation events."@en ;
                         rdfs:label "consolidation order"@en ;
                         adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


#################################################################
#    Classes
#################################################################

adr-o:Alternative rdf:type owl:Class ;
                  rdfs:comment "An option considered during a decision. First-class nodes enable traversal of rejected alternatives."@en ;
                  rdfs:label "Alternative"@en ;
                  adr-o:justifiedBy adr-odr:ADR-0012-alternatives-and-chosen-option .


adr-o:Concern rdf:type owl:Class ;
              rdfs:comment "A matter of interest or importance to a stakeholder (ISO 42010). Abstract anchor class; domain-specific concerns are instantiated via SKOS schemes."@en ;
              rdfs:label "Concern"@en ;
              adr-o:justifiedBy adr-odr:ADR-0002-scope .


adr-o:Claim rdf:type owl:Class ;
                    rdfs:comment "A reusable atomic proposition that can be asserted in one or more fact roles within a DecisionRecord. A Claim is verifiable and carries truth value under observation."@en ;
                    rdfs:label "Claim"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts ,
                                      adr-odr:ADR-0028-integrating-the-decision-transaction-principle ,
                                      adr-odr:ADR-0031-rename-consideration-claim,
                                      adr-odr:ADR-0033-observation-discovery .


adr-o:Complaint rdf:type owl:Class ;
                rdfs:subClassOf prov:Entity ;
                rdfs:comment "The raw, pre-analytical triggering statement that caused a DecisionRecord to exist. Named by a stakeholder at a specific moment, in ordinary language, before any sharpening or translation into a falsifiable need."@en ;
                rdfs:label "Complaint"@en ;
                skos:scopeNote "Not a Claim: carries no truth value. Constitutive of the record's identity — a changed Complaint is a different fish, not a revised record. Distinct from adr-o:authoredBy (record author) and adr-o:decidedBy (decision-maker)."@en ;
                adr-o:justifiedBy adr-odr:ADR-0037-complaint-reification .


adr-o:ContextFact rdf:type owl:Class ;
                  rdfs:comment "Reified link placing a Claim into framing: situational facts, constraints, and prior assumptions."@en ;
                  rdfs:label "Context Fact"@en ;
                  adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts .


adr-o:DecisionRecord rdf:type owl:Class ;
                     rdfs:subClassOf prov:Entity ;
                     rdfs:comment "A record of a single, load-bearing decision. Domain-agnostic core."@en ;
                     rdfs:label "Decision Record"@en ;
                     adr-o:justifiedBy adr-odr:ADR-0002-scope .


[ rdf:type owl:Class ;
  owl:intersectionOf ( adr-o:DecisionRecord
                       [ rdf:type owl:Restriction ;
                         owl:onProperty adr-o:hasStatus ;
                         owl:hasValue adr-o:Superseded
                       ]
                     ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty adr-o:supersededBy ;
                    owl:someValuesFrom adr-o:DecisionRecord
                  ] ;
  rdfs:comment "Constraint: a DecisionRecord with status Superseded must link to at least one successor record via adr-o:supersededBy."@en ;
  adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity ,
                    adr-odr:ADR-0041-deprecation-requires-a-deprecating-record
] .


[ rdf:type owl:Class ;
  owl:intersectionOf ( adr-o:DecisionRecord
                       [ rdf:type owl:Restriction ;
                         owl:onProperty adr-o:hasStatus ;
                         owl:hasValue adr-o:Deprecated
                       ]
                     ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty adr-o:deprecatedBy ;
                    owl:someValuesFrom adr-o:DecisionRecord
                  ] ;
  rdfs:comment "Constraint: a DecisionRecord with status Deprecated must link to at least one deprecating record via adr-o:deprecatedBy."@en ;
  adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity ,
                    adr-odr:ADR-0041-deprecation-requires-a-deprecating-record
] .


adr-o:DeliberationFact rdf:type owl:Class ;
                       rdfs:comment "Reified link placing a Claim into deliberation against an Alternative with a valence."@en ;
                       rdfs:label "Deliberation Fact"@en ;
                       adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts .


adr-o:DeliberationValence rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( skos:Concept
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty skos:inScheme ;
                                                                       owl:hasValue adr-o:deliberationValenceScheme
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf skos:Concept ;
                          rdfs:comment "Valence of a DeliberationFact: Supports, Against, or Neutral."@en ;
                          rdfs:label "Deliberation Valence"@en ;
                          adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence .


adr-o:DiscoveryType rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( skos:Concept
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty skos:inScheme ;
                                                                 owl:hasValue adr-o:discoveryTypeScheme
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf skos:Concept ;
                    rdfs:comment "Classification of an ObservedOutcome relative to t₀ expectations: Expected, Deducible, or Emergent."@en ;
                    rdfs:label "Discovery Type"@en ;
                    adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:ExpectedOutcome rdf:type owl:Class ;
                      rdfs:comment "A t₀ commitment about what the chosen alternative is intended to produce. Not a tₙ observation."@en ;
                      rdfs:label "Expected Outcome"@en ;
                      adr-o:justifiedBy adr-odr:ADR-0010-consideration-and-reified-facts ,
                                        adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:ExpectedOutcomeValence rdf:type owl:Class ;
                             owl:equivalentClass [ owl:intersectionOf ( skos:Concept
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty skos:inScheme ;
                                                                          owl:hasValue adr-o:expectedOutcomeValenceScheme
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ] ;
                             rdfs:subClassOf skos:Concept ;
                             rdfs:comment "The intended valence of an ExpectedOutcome: ExpectedGain, ExpectedCost, ExpectedRisk, or ExpectedDependency."@en ;
                             rdfs:label "Expected Outcome Valence"@en ;
                             adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                               adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:ObservedOutcome rdf:type owl:Class ;
                  rdfs:subClassOf prov:Entity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty adr-o:manifests ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass adr-o:Claim
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty adr-o:realizedFrom ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass adr-o:DecisionRecord
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty adr-o:discoveryType ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass adr-o:DiscoveryType
                                  ] ;
                  rdfs:comment "A first-class tₙ fact that captures a realized effect linked to a source DecisionRecord. ObservedOutcome may optionally verify an ExpectedOutcome and carry a verdict."@en ;
                  rdfs:label "ObservedOutcome"@en ;
                  adr-o:justifiedBy adr-odr:ADR-0030-observations ,
                                    adr-odr:ADR-0033-observation-discovery ,
                                    adr-odr:ADR-0035-observedoutcome-prov-entity .


adr-o:ObservedOutcomeVerdict rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( skos:Concept
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty skos:inScheme ;
                                                                    owl:hasValue adr-o:ObservedOutcomeVerdictScheme
                                                                  ]
                                                                ) ;
                                              rdf:type owl:Class
                                            ] ;
                         rdfs:subClassOf skos:Concept ;
                         rdfs:comment "The verdict of an ObservedOutcome."@en ;
                         rdfs:label "ObservedOutcome Verdict"@en ;
                         adr-o:justifiedBy adr-odr:ADR-0030-observations .


[ rdf:type owl:Class ;
  owl:intersectionOf ( adr-o:ObservedOutcome
                       [ rdf:type owl:Restriction ;
                         owl:onProperty adr-o:hasVerdict ;
                         owl:someValuesFrom adr-o:ObservedOutcomeVerdict
                       ]
                     ) ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty adr-o:verifies ;
                    owl:someValuesFrom adr-o:ExpectedOutcome
                  ]
] .


adr-o:Verdict rdf:type owl:Class ;
              rdfs:comment "The reified convergence act of a decision: the moment deliberation closed and a commitment was made. Carries the author's account of how the balance tipped, including trade-offs consciously accepted."@en ;
              rdfs:label "Verdict"@en ;
              skos:scopeNote "Not a Claim: carries no truth value. Tier 1 epistemic core — mutable during drafting, frozen on external reference per the Decision Transaction Principle. The prose content (dcterms:description typed adr-o:md) is where the Y-statement 'accepting that' clause lives."@en ;
              adr-o:justifiedBy adr-odr:ADR-0040-verdict-reification .


adr-o:Status rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( skos:Concept
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty skos:inScheme ;
                                                          owl:hasValue adr-o:statusScheme
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf skos:Concept ;
             rdfs:comment "A lifecycle status for a DecisionRecord. Range of adr-o:hasStatus."@en ;
             rdfs:label "Status"@en ;
             adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:ConsolidatedADL rdf:type owl:Class ;
                      rdfs:comment "A disposable, LLM-maintained cache of the currently operative commitments across an ADL. Contains an ordered collection of ConsolidatedOutcome entries, each tracing to its source ExpectedOutcome via adr-o:consolidatedFrom."@en ;
                      rdfs:label "Consolidated ADL"@en ;
                      skos:scopeNote "Not a DecisionRecord and not part of the enacted layer. Eternally mutable: entries may be edited, replaced, or removed as the ADL evolves. One instance per ADL in normal use — multiple instances would recreate the normative fragmentation the consolidated layer exists to prevent. Does not subclass prov:Entity: the PROV alignment test (ADR-0035) fails at fixed-aspects; ConsolidatedADL is explicitly mutable by design."@en ;
                      adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


adr-o:ConsolidatedOutcome rdf:type owl:Class ;
                          rdfs:comment "An entry in a ConsolidatedADL representing the current operative text of an ExpectedOutcome. Carries back-links to its source ExpectedOutcome(s) via adr-o:consolidatedFrom. Mutable: may be edited in place by subsequent amendments without producing a new IRI."@en ;
                          rdfs:label "Consolidated Outcome"@en ;
                          skos:scopeNote "Not a Claim: carries no deliberative truth value (ADR-0031). Not subject to verification or observation. Its structural value is the source-map link (adr-o:consolidatedFrom) connecting the operative surface to the frozen enacted layer. Analogous to a debug-build symbol table entry."@en ;
                          adr-o:justifiedBy adr-odr:ADR-0043-consolidated-adl .


#################################################################
#    Individuals
#################################################################

adr-o:Accepted rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The decision is in force. Default steady-state status."@en ;
               skos:inScheme adr-o:statusScheme ;
               skos:prefLabel "Accepted"@en ;
               skos:topConceptOf adr-o:statusScheme ;
               adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:ExpectedCost rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:definition "The Claim is a cost voluntarily accepted at t₀ — the \"accepting-that\" commitment."@en ;
                   skos:inScheme adr-o:expectedOutcomeValenceScheme ;
                   skos:prefLabel "Expected Cost"@en ;
                   skos:topConceptOf adr-o:expectedOutcomeValenceScheme ;
                   adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                     adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:Deducible rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:definition "The outcome was a logical consequence of the decision, but not explicitly predicted at t₀."@en ;
                skos:inScheme adr-o:discoveryTypeScheme ;
                skos:prefLabel "Deducible"@en ;
                skos:topConceptOf adr-o:discoveryTypeScheme ;
                adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:Emergent rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The outcome arose through interaction with the environment and was not predictable at t₀."@en ;
               skos:inScheme adr-o:discoveryTypeScheme ;
               skos:prefLabel "Emergent"@en ;
               skos:topConceptOf adr-o:discoveryTypeScheme ;
               adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:Expected rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The outcome was explicitly predicted at t₀."@en ;
               skos:inScheme adr-o:discoveryTypeScheme ;
               skos:prefLabel "Expected"@en ;
               skos:topConceptOf adr-o:discoveryTypeScheme ;
               adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:Against rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:definition "The Claim weighs against the Alternative."@en ;
              skos:inScheme adr-o:deliberationValenceScheme ;
              skos:prefLabel "Against"@en ;
              skos:topConceptOf adr-o:deliberationValenceScheme ;
              adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence .


adr-o:ExpectedGain rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:definition "The Claim is a positive outcome expected at t₀."@en ;
                   skos:inScheme adr-o:expectedOutcomeValenceScheme ;
                   skos:prefLabel "Expected Gain"@en ;
                   skos:topConceptOf adr-o:expectedOutcomeValenceScheme ;
                   adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                     adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:Deprecated rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 rdfs:seeAlso adr-o:Superseded ;
                 skos:definition "The decision is no longer recommended but has no specific successor."@en ;
                 skos:inScheme adr-o:statusScheme ;
                 skos:prefLabel "Deprecated"@en ;
                 skos:topConceptOf adr-o:statusScheme ;
                 adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:ExpectedDependency rdf:type owl:NamedIndividual ,
                                  skos:Concept ;
                         skos:definition "The Claim represents work or further deliberation triggered at t₀."@en ;
                         skos:inScheme adr-o:expectedOutcomeValenceScheme ;
                         skos:prefLabel "Expected Dependency"@en ;
                         skos:topConceptOf adr-o:expectedOutcomeValenceScheme ;
                         adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                           adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:Neutral rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:definition "The Claim is in scope but does not weigh either way."@en ;
              skos:inScheme adr-o:deliberationValenceScheme ;
              skos:prefLabel "Neutral"@en ;
              skos:topConceptOf adr-o:deliberationValenceScheme ;
              adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence .


adr-o:Proposed rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The decision has been drafted but not yet accepted."@en ;
               skos:inScheme adr-o:statusScheme ;
               skos:prefLabel "Proposed"@en ;
               skos:topConceptOf adr-o:statusScheme ;
               adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:Rejected rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The decision was proposed and explicitly declined."@en ;
               skos:inScheme adr-o:statusScheme ;
               skos:prefLabel "Rejected"@en ;
               skos:topConceptOf adr-o:statusScheme ;
               adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:ExpectedRisk rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:definition "A possible negative outcome acknowledged at t₀."@en ;
                   skos:inScheme adr-o:expectedOutcomeValenceScheme ;
                   skos:prefLabel "Expected Risk"@en ;
                   skos:topConceptOf adr-o:expectedOutcomeValenceScheme ;
                   adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                     adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:Inconclusive rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:definition "The available evidence is insufficient to determine whether the expected outcome was realised."@en ;
                   skos:inScheme adr-o:ObservedOutcomeVerdictScheme ;
                   skos:prefLabel "Inconclusive"@en ;
                   skos:topConceptOf adr-o:ObservedOutcomeVerdictScheme ;
                   adr-o:justifiedBy adr-odr:ADR-0030-observations .


adr-o:Superseded rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 rdfs:seeAlso adr-o:Deprecated ;
                 skos:definition "The decision has been replaced by a successor."@en ;
                 skos:inScheme adr-o:statusScheme ;
                 skos:prefLabel "Superseded"@en ;
                 skos:topConceptOf adr-o:statusScheme ;
                 adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


adr-o:Supports rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The Claim weighs in favour of the Alternative."@en ;
               skos:inScheme adr-o:deliberationValenceScheme ;
               skos:prefLabel "Supports"@en ;
               skos:topConceptOf adr-o:deliberationValenceScheme ;
               adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence .


adr-o:Satisfied rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:definition "The expected outcome was realised according to the observation verdict."@en ;
                skos:inScheme adr-o:ObservedOutcomeVerdictScheme ;
                skos:prefLabel "Satisfied"@en ;
                skos:topConceptOf adr-o:ObservedOutcomeVerdictScheme ;
                adr-o:justifiedBy adr-odr:ADR-0030-observations .


adr-o:Violated rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:definition "The expected outcome was not realised according to the observation verdict."@en ;
               skos:inScheme adr-o:ObservedOutcomeVerdictScheme ;
               skos:prefLabel "Violated"@en ;
               skos:topConceptOf adr-o:ObservedOutcomeVerdictScheme ;
               adr-o:justifiedBy adr-odr:ADR-0030-observations .


adr-o:deliberationValenceScheme rdf:type owl:NamedIndividual ,
                                         skos:ConceptScheme ;
                                dcterms:title "ADR-O Deliberation Valence Scheme"@en ;
                                rdfs:comment "Controlled vocabulary of DeliberationFact valences."@en ;
                                skos:hasTopConcept adr-o:Against ,
                                                   adr-o:Neutral ,
                                                   adr-o:Supports ;
                                adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence .


adr-o:discoveryTypeScheme rdf:type owl:NamedIndividual ,
                                   skos:ConceptScheme ;
                          dcterms:title "ObservedOutcome Discovery Type Scheme"@en ;
                          rdfs:comment "Controlled vocabulary classifying how an observed effect relates to t₀ expectations."@en ;
                          skos:hasTopConcept adr-o:Deducible ,
                                             adr-o:Emergent ,
                                             adr-o:Expected ;
                          adr-o:justifiedBy adr-odr:ADR-0033-observation-discovery .


adr-o:expectedOutcomeValenceScheme rdf:type owl:NamedIndividual ,
                                            skos:ConceptScheme ;
                                   dcterms:title "Expected Outcome Valence Scheme"@en ;
                                   rdfs:comment "t₀ claims about intended outcomes. None are guarantees."@en ;
                                   skos:hasTopConcept adr-o:ExpectedCost ,
                                                      adr-o:ExpectedGain ,
                                                      adr-o:ExpectedDependency ,
                                                      adr-o:ExpectedRisk ;
                                   adr-o:justifiedBy adr-odr:ADR-0009-deliberation-and-outcome-valence ,
                                                     adr-odr:ADR-0028-integrating-the-decision-transaction-principle .


adr-o:ObservedOutcomeVerdictScheme rdf:type owl:NamedIndividual ,
                                        skos:ConceptScheme ;
                               dcterms:title "ObservedOutcome Verdict Scheme"@en ;
                               rdfs:comment "Controlled vocabulary of ObservedOutcome verdicts."@en ;
                               skos:hasTopConcept adr-o:Inconclusive ,
                                                  adr-o:Satisfied ,
                                                  adr-o:Violated ;
                               adr-o:justifiedBy adr-odr:ADR-0030-observations .


adr-o:statusScheme rdf:type owl:NamedIndividual ,
                            skos:ConceptScheme ;
                   dcterms:title "ADR-O Status Scheme"@en ;
                   rdfs:comment "Controlled vocabulary of DecisionRecord lifecycle statuses."@en ;
                   skos:hasTopConcept adr-o:Accepted ,
                                      adr-o:Deprecated ,
                                      adr-o:Proposed ,
                                      adr-o:Rejected ,
                                      adr-o:Superseded ;
                   adr-o:justifiedBy adr-odr:ADR-0008-status-skos-and-integrity .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( adr-o:Accepted
                        adr-o:Deprecated
                        adr-o:Proposed
                        adr-o:Rejected
                        adr-o:Superseded
                      ) ;
  rdfs:comment "Ensures status individuals are distinct so that adr-o:hasStatus (functional) catches duplicate-status misannotations as inconsistencies."@en
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( adr-o:ExpectedCost
                        adr-o:ExpectedGain
                        adr-o:ExpectedDependency
                        adr-o:ExpectedRisk
                      ) ;
  rdfs:comment "Ensures expected outcome valences are distinct so that adr-o:outcomeValence (functional) catches duplicate-valence misannotations."@en
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( adr-o:Against
                        adr-o:Neutral
                        adr-o:Supports
                      ) ;
  rdfs:comment "Ensures deliberation valences are distinct so that adr-o:deliberationValence (functional) catches duplicate-valence misannotations."@en
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( adr-o:Inconclusive
                        adr-o:Satisfied
                        adr-o:Violated
                      ) ;
  rdfs:comment "Ensures observation verdicts are distinct so that adr-o:hasVerdict (functional) catches duplicate-verdict misannotations."@en
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( adr-o:Deducible
                        adr-o:Emergent
                        adr-o:Expected
                      ) ;
  rdfs:comment "Ensures discovery types are distinct so that adr-o:discoveryType (functional) catches duplicate-type misannotations."@en
] .
